# =============================================================
# RECOMBYNE — BRING YOUR OWN API KEYS
# Copy this file to .env and fill in your own credentials.
# Never commit your .env file. It is in .gitignore.
# See docs/byoa-setup.md for step-by-step instructions on
# obtaining each key.
# =============================================================

# X (Twitter) API v2
# Required for Twitter ingestion
# Get yours at: https://developer.twitter.com/en/portal/dashboard
TWITTER_BEARER_TOKEN=

# Reddit API
# Required for Reddit ingestion
# Get yours at: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=RecombyneDev/0.1 (by u/YOUR_REDDIT_USERNAME)

# HuggingFace (optional)
# Used as fallback if local RoBERTa model fails to load
# Get yours at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# Database
DATABASE_URL=postgresql+asyncpg://recombyne:recombyne@localhost:5432/recombyne

# Redis
REDIS_URL=redis://localhost:6379/0

# App
ENVIRONMENT=development
SECRET_KEY=change-this-to-a-random-string-in-production
API_CORS_ORIGINS=http://localhost:3000
